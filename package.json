{
  "name": "edufixer",
  "version": "0.1.2",
  "private": true,
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:electron",
    "dev:react": "vite --open /index_vite_backup.html",
    "dev:electron": "cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173/index_vite_backup.html concurrently -k \"vite --host 127.0.0.1 --strictPort\" \"wait-on http://127.0.0.1:5173/index_vite_backup.html && node tools/run-electron.cjs\"",
    "start": "node tools/run-electron.cjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "dist:win": "npm run build && electron-builder --win nsis",
    "dist:win:publish": "npm run build && electron-builder --win nsis --publish always",
    "lint": "eslint .",
    "typecheck": "tsc -b --pretty false",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest"
  },
  "build": {
    "appId": "net.enaru.edufixer",
    "productName": "edufixer",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "scripts/**/*",
      "tools/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "scripts",
        "to": "scripts",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "rio7710",
      "repo": "eduPlan",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@tiptap/extension-image": "^3.20.2",
    "@tiptap/extension-table": "^3.20.2",
    "@tiptap/extension-table-cell": "^3.20.2",
    "@tiptap/extension-table-header": "^3.20.2",
    "@tiptap/extension-table-row": "^3.20.2",
    "@tiptap/react": "^3.20.2",
    "@tiptap/starter-kit": "^3.20.2",
    "@uiw/react-codemirror": "^4.25.8",
    "dompurify": "^3.3.3",
    "electron-updater": "^6.6.2",
    "marked": "^17.0.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tiptap-markdown": "^0.9.0",
    "turndown": "^7.2.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.5",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^17.4.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "wait-on": "^9.0.4"
  }
}
